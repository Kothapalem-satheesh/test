# =============================================================================
# ComplianceAI Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# --- LLM Provider: groq | anthropic ---
LLM_PROVIDER=groq

# --- Groq LLM (recommended - fast, cost-effective) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Anthropic LLM (Claude) - alternative ---
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Node/Express Server ---
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Internal secret shared between Express and Python service
INTERNAL_SERVICE_SECRET=change-this-to-a-long-random-string

# --- Python FastAPI Microservice ---
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_PORT=8000

# --- Client (Vite) ---
VITE_API_URL=http://localhost:3001/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Upload limits ---
MAX_FILE_SIZE_MB=25
ALLOWED_FILE_TYPES=pdf,docx,txt,md,xlsx

# --- Analysis & retrieval settings ---
TOP_K_CHUNKS=8
SIMILARITY_THRESHOLD=0.32
ANALYSIS_CONCURRENCY=3
EMBED_BATCH_SIZE=64
EMBEDDING_DIMENSIONS=384
